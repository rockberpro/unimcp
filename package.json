    "mcp": "bun src/mcp/cli.ts",
    "help": "bun src/mcp/cli.ts --help"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.25.10",
    "zod": "^4.3.6"
  }
}