{
  "name": "unimcp",
  "version": "0.1.0",
  "description": "Generic codebase-awareness MCP server. Drop into any PHP/TS/Python project to give agents file, symbol, and framework-aware context.",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "unimcp": "src/mcp/cli.ts"
  },
  "scripts": {
    "test": "bun test",
